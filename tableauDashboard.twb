              <calculation class='tableau' formula='&quot;O. Dembélé&quot;' />
            </column>
            <column alias='xG Per90' caption='Y Axis Metrics' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;xgPer90&quot;'>
              <calculation class='tableau' formula='&quot;xgPer90&quot;' />
              <aliases>
                <alias key='&quot;accuratePasses&quot;' value='Accurate Passes' />
                <alias key='&quot;accuratePassesPer90&quot;' value='Accurate Passes Per90' />
                <alias key='&quot;aerialsWon&quot;' value='Aerial Duels Won' />
                <alias key='&quot;aerialsWonPer90&quot;' value='Aerial Duels Won Per90' />
                <alias key='&quot;assistsPer90&quot;' value='Assists Per90' />
                <alias key='&quot;bigChancesCreated&quot;' value='Big Chances Created' />
                <alias key='&quot;bigChancesCreatedPer90&quot;' value='Big Chances Created Per90' />
                <alias key='&quot;blocksPer90&quot;' value='Blocks Per90' />
                <alias key='&quot;clearancesPer90&quot;' value='Clearances Per90' />
                <alias key='&quot;crossesPer90&quot;' value='Crosses Per90' />
                <alias key='&quot;duelsWon&quot;' value='Ground Duels Won' />
