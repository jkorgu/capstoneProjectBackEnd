              <calculation class='tableau' formula='[Name] = [Parameters].[Parameter 1] OR [Name] = [Parameters].[Parameter 2]' />
            </column>
            <column caption='Comparison Colours' datatype='string' name='[Calculation_2934658169807470593]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Name] = [Parameters].[Parameter 1] THEN &quot;Player 1&quot;&#13;&#10;ELSEIF [Name] = [Parameters].[Parameter 2] THEN &quot;Player 2&quot;&#13;&#10;ELSE NULL&#13;&#10;END' />
            </column>
            <column caption='Y Axis Metrics SETUP' datatype='real' name='[Calculation_2934658169823039492]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &quot;Mins&quot; THEN [Mins]&#13;&#10;WHEN &quot;Assists&quot; THEN [Assists]&#13;&#10;WHEN &quot;Shots&quot; THEN [Shots]&#13;&#10;WHEN &quot;shotsOnTarget&quot; THEN [shotsOnTarget]&#13;&#10;WHEN &quot;Goals&quot; THEN [Goals]&#13;&#10;WHEN &quot;xG&quot; THEN [xG]&#13;&#10;WHEN &quot;npxG&quot; THEN [npxG]&#13;&#10;WHEN &quot;xA&quot; THEN [xA]&#13;&#10;WHEN &quot;Tackles&quot; THEN [Tackles]&#13;&#10;WHEN &quot;Clearances&quot; THEN [Clearances]&#13;&#10;WHEN &quot;Interceptions&quot; THEN [Interceptions]&#13;&#10;WHEN &quot;aerialsWon&quot; THEN [aerialsWon]&#13;&#10;WHEN &quot;Blocks&quot; THEN [Blocks]&#13;&#10;WHEN &quot;duelsWon&quot; THEN [duelsWon]&#13;&#10;WHEN &quot;Passes&quot; THEN [Passes]&#13;&#10;WHEN &quot;accuratePasses&quot; THEN [accuratePasses]&#13;&#10;WHEN &quot;longBalls&quot; THEN [longBalls]&#13;&#10;WHEN &quot;Crosses&quot; THEN [Crosses]&#13;&#10;WHEN &quot;bigChancesCreated&quot; THEN [bigChancesCreated]&#13;&#10;WHEN &quot;keyPasses&quot; THEN [keyPasses]&#13;&#10;WHEN &quot;Saves&quot; THEN [Saves]&#13;&#10;WHEN &quot;goalsPer90&quot; THEN [goalsPer90]&#13;&#10;WHEN &quot;assistsPer90&quot; THEN [assistsPer90]&#13;&#10;WHEN &quot;g+a&quot; THEN [g+a]&#13;&#10;WHEN &quot;g+aPer90&quot; THEN [g+aPer90]&#13;&#10;WHEN &quot;shotsPer90&quot; THEN [shotsPer90]&#13;&#10;WHEN &quot;shotsOnTargetPer90&quot; THEN [shotsOnTargetPer90]&#13;&#10;WHEN &quot;longBallsPer90&quot; THEN [longBallsPer90]&#13;&#10;WHEN &quot;crossesPer90&quot; THEN [crossesPer90]&#13;&#10;WHEN &quot;bigChancesCreatedPer90&quot; THEN [bigChancesCreatedPer90]&#13;&#10;WHEN &quot;keyPassesPer90&quot; THEN [keyPassesPer90]&#13;&#10;WHEN &quot;tacklesPer90&quot; THEN [tacklesPer90]&#13;&#10;WHEN &quot;clearancesPer90&quot; THEN [clearancesPer90]&#13;&#10;WHEN &quot;interceptionsPer90&quot; THEN [interceptionsPer90]&#13;&#10;WHEN &quot;aerialsWonPer90&quot; THEN [aerialsWonPer90]&#13;&#10;WHEN &quot;blocksPer90&quot; THEN [blocksPer90]&#13;&#10;WHEN &quot;savesPer90&quot; THEN [savesPer90]&#13;&#10;WHEN &quot;xgPer90&quot; THEN [xgPer90]&#13;&#10;WHEN &quot;npxgPer90&quot; THEN [npxgPer90]&#13;&#10;WHEN &quot;xaPer90&quot; THEN [xaPer90]&#13;&#10;WHEN &quot;passAccuracy&quot; THEN [passAccuracy]&#13;&#10;END' />
            </column>
            <column datatype='integer' name='[Clearances]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Crosses]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Goals]' role='measure' type='quantitative' />
