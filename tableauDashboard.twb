                <alias key='&quot;interceptionsPer90&quot;' value='Interceptions Per90' />
                <alias key='&quot;keyPasses&quot;' value='Key Passes' />
                <alias key='&quot;keyPassesPer90&quot;' value='Key Passes Per90' />
                <alias key='&quot;longBalls&quot;' value='Long Balls' />
                <alias key='&quot;longBallsPer90&quot;' value='Long Balls Per90' />
                <alias key='&quot;Mins&quot;' value='Minutes Played' />
                <alias key='&quot;npxgPer90&quot;' value='npxG Per90' />
                <alias key='&quot;passAccuracy&quot;' value='Pass Accuracy (%)' />
                <alias key='&quot;passesPer90&quot;' value='Passes Per90' />
                <alias key='&quot;savesPer90&quot;' value='Saves Per90' />
                <alias key='&quot;shotsOnTarget&quot;' value='Shots on Target' />
                <alias key='&quot;shotsOnTargetPer90&quot;' value='Shots On Target Per90' />
                <alias key='&quot;shotsPer90&quot;' value='Shots Per90' />
                <alias key='&quot;tacklesPer90&quot;' value='Tackles Per90' />
                <alias key='&quot;xaPer90&quot;' value='xA Per90' />
                <alias key='&quot;xgPer90&quot;' value='xG Per90' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0hztoz105637751ddzfsw1ytrj7a'>
